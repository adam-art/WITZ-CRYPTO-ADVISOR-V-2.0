# ════════════════════════════════════════════════════════════
#  WITZ — Environment Variables
#  Salin file ini ke .env.local lalu isi API key Anda
#  cp .env.example .env.local
#
#  ⚠️  JANGAN pernah commit .env.local ke Git!
#     File ini sudah ada di .gitignore
# ════════════════════════════════════════════════════════════


# ── AI PROVIDERS (pilih minimal 1) ──────────────────────────
# Pilih provider yang Anda miliki key-nya. Semua opsional,
# tapi minimal 1 harus diisi agar fitur WITZ AI berfungsi.

# 1. Anthropic Claude (Direkomendasikan — paling akurat)
#    Daftar gratis di: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-api03-ganti-dengan-key-anda

# 2. OpenAI GPT-4o
#    Daftar di: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-ganti-dengan-key-anda

# 3. Google Gemini Pro
#    Daftar gratis di: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIza-ganti-dengan-key-anda

# 4. Groq (Llama 3.3 — GRATIS & sangat cepat)
#    Daftar gratis di: https://console.groq.com
VITE_GROQ_API_KEY=gsk_ganti-dengan-key-anda


# ── MARKET DATA ──────────────────────────────────────────────
# CoinGecko Free — TIDAK perlu API key
# Data otomatis berfungsi tanpa konfigurasi apapun


# ── DATABASE (opsional — untuk data persistent) ──────────────
# Supabase gratis di: https://supabase.com
VITE_SUPABASE_URL=https://project-id-anda.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...


# ── APP CONFIG ───────────────────────────────────────────────
VITE_APP_ENV=development
VITE_APP_NAME=WITZ
